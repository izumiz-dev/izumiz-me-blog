{
  "name": "izumiz-me-blog",
  "type": "module",
  "version": "0.6.3",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:cached": "pnpm run cache:fetch && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --ext .js,.ts,.astro src",
    "format": "prettier --write . '**/*.{ts,astro,css,yaml,json,yml}'",
    "cache:fetch": "node scripts/blog-contents-cache.cjs",
    "cache:purge": "nx reset && rm -f tmp/*",
    "_fetch-notion-blocks": "node scripts/retrieve-block-children.cjs"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@notionhq/client": "^2.3.0",
    "@supercharge/promise-pool": "^2.4.0",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "astro": "^5.16.15",
    "astro-icon": "^1.1.5",
    "async-retry": "^1.3.3",
    "axios": "^1.13.2",
    "exif-be-gone": "^1.3.2",
    "katex": "^0.16.7",
    "mermaid": "^11.12.2",
    "metascraper": "^5.49.19",
    "metascraper-description": "^5.49.19",
    "metascraper-image": "^5.49.19",
    "metascraper-title": "^5.49.19",
    "node-fetch": "^3.3.2",
    "normalize-url": "^8.1.1",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.6.1",
    "@iconify-json/octicon": "^1.2.20",
    "@nrwl/nx-cloud": "^19.1.0",
    "@resvg/resvg-js": "^2.6.0",
    "@types/async-retry": "^1.4.5",
    "@types/js-base64": "^3.3.1",
    "@types/katex": "^0.16.7",
    "@types/metascraper": "^5.14.1",
    "@types/metascraper-description": "^5.14.1",
    "@types/metascraper-image": "^5.14.0",
    "@types/metascraper-title": "^5.14.0",
    "@types/prismjs": "^1.26.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "astro-seo": "^1.1.0",
    "cli-progress": "^3.12.0",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.5.0",
    "lefthook": "^1.5.5",
    "nx": "22.4.1",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.12.3",
    "satori": "^0.10.11",
    "sharp": "^0.34.5"
  },
  "nx": {
    "targets": {
      "_fetch-notion-blocks": {
        "inputs": [
          "!{projectRoot}/**/*",
          "!{projectRoot}/**/.*",
          "!{projectRoot}/**/.*/**/*",
          {
            "env": "DATABASE_ID"
          }
        ],
        "outputs": [
          "{projectRoot}/tmp"
        ]
      }
    },
    "includedScripts": [
      "_fetch-notion-blocks"
    ]
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.4",
      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "brace-expansion": ">=2.0.2",
      "js-yaml": ">=4.1.1"
    }
  }
}
