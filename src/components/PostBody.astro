---
import { Block } from '@lib/interfaces.ts';
import NotionBlocks from './NotionBlocks.astro';

export interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
---

<div class="post-body">
  <NotionBlocks blocks={blocks} isRoot={true} />
</div>

<style>
  .post-body {
    max-width: 840px;
    padding: 0.5rem 0;
  }
  .post-body :global(p a),
  .post-body :global(li a) {
    text-decoration: underline;
    text-underline-offset: 0.25em;
    text-decoration-thickness: 0.06em;
    text-decoration-color: color-mix(in oklab, currentColor 40%, transparent);
    transition: text-decoration-color 0.15s ease;
  }
  .post-body :global(p a:hover),
  .post-body :global(li a:hover) {
    text-decoration-color: currentColor;
  }
  /* Text blocks fill the 840px .post-body column (52.5rem cap), media/code
     stay wide too. The old clamp(32rem, 62ch, 44rem) capped text at ~668px:
     `ch` keys off the half-width "0" glyph, so 62ch collapsed to ~20
     full-width chars/line and left a large right-hand gutter on wide
     viewports while forcing awkward mid-phrase wraps. Using the full column
     removes that gutter; kinsoku (below) keeps the longer lines readable. */
  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol),
  .post-body :global(h3),
  .post-body :global(h4),
  .post-body :global(h5),
  .post-body :global(blockquote),
  .post-body :global(.table-of-contents),
  .post-body :global(hr) {
    max-width: min(52.5rem, 100%);
    /* Respect Japanese kinsoku; the body sets overflow-wrap: anywhere,
       which breaks mid-phrase. Restrict breaks to long unbreakable runs
       (URLs, long ASCII tokens) so words/phrases stay intact. */
    word-break: normal;
    overflow-wrap: break-word;
    line-break: strict;
  }
  @media (max-width: 640px) {
    .post-body :global(p),
    .post-body :global(ul),
    .post-body :global(ol),
    .post-body :global(h3),
    .post-body :global(h4),
    .post-body :global(h5),
    .post-body :global(blockquote),
    .post-body :global(.table-of-contents),
    .post-body :global(hr) {
      max-width: 100%;
    }
  }
</style>
