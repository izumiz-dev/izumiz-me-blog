---
import type { GalleryItem } from '../lib/interfaces';
import { getFeaturedImageUrl, getDateStr } from '../lib/blog-helpers';

export interface Props {
  post: GalleryItem;
}

const { post } = Astro.props;
const title = post.Title;
const imageUrl = getFeaturedImageUrl(post.FeaturedImage);
---

<div class="gallery-tile">
  <div
    class:list={['gallery-thumb-wrap', imageUrl ? 'open-gallery-preview' : '']}
    data-preview-image={imageUrl || undefined}
    data-preview-title={title}
    data-preview-date={post.Date ? getDateStr(post.Date) : ''}
  >
    {
      imageUrl && (
        <img class="gallery-thumb" src={imageUrl} alt={title} loading="lazy" />
      )
    }
  </div>
  <h2 class="post-title" title={title}>
    {title}
  </h2>
</div>

<style>
  .gallery-tile {
    display: flex;
    flex-direction: column;
  }

  /* 1:1 サムネイル(GalleryImage の .image-container と同見た目)。
     open-gallery-preview が付与されていればクリックでモーダル起動。 */
  .gallery-thumb-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--chrome-border);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      0 3px 12px rgba(20, 40, 80, 0.12);
  }
  @media (prefers-color-scheme: dark) {
    .gallery-thumb-wrap {
      box-shadow:
        inset 0 1px 0 var(--chrome-rim),
        0 3px 14px rgba(0, 0, 0, 0.35);
    }
  }
  .gallery-thumb-wrap.open-gallery-preview {
    cursor: pointer;
  }

  .gallery-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .post-title {
    margin: 0.5rem 0 0;
    font-size: 1rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%; /* 親要素の幅に合わせるために追加 */
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 0.9rem;
    }
  }
</style>
