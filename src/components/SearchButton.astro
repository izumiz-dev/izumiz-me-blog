---
import { Icon } from 'astro-icon/components';
---

<button class="search-button open-search-modal" type="button"
  ><Icon name="octicon:search-24" /><span>Search</span></button
>

<style>
  .search-button {
    display: flex;
    align-items: center;
    width: 100%;
    margin-bottom: 0.5rem;
    border-radius: 9999px;
    padding: 0.4rem 0.8rem;
    color: var(--fg);
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--chrome-gradient);
    border: 1px solid var(--chrome-border);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      inset 0 -1px 0 var(--chrome-rim-bottom),
      0 1px 2px rgba(0, 0, 0, 0.08);
    transition:
      filter 0.2s ease,
      transform 0.2s ease;
  }
  .search-button:hover {
    cursor: pointer;
    filter: brightness(1.04);
    transform: translateY(-1px);
  }
  .search-button:focus-visible {
    outline: 2px solid var(--aqua-mid);
    outline-offset: 2px;
  }
  .search-button svg {
    width: 20px;
    height: 20px;
    margin-right: 0.2rem;
  }
  [astro-icon='octicon:search-24'] {
    color: var(--fg);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    function handleKeydown(event) {
      if (event.keyCode === 75 && event.metaKey) {
        // Ctrl+K or Cmd+K
        document.querySelector('.open-search-modal').click();
      }
    }

    document.addEventListener('keydown', handleKeydown);
  });
</script>
