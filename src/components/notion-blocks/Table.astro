---
import * as interfaces from '../../lib/interfaces.ts';
import RichText from './RichText.astro';

export interface Props {
  block: interfaces.Block;
}

const { block } = Astro.props;
---

<div class="table">
  <table>
    <tbody>
      {
        block.Table.Rows.map((tableRow: interfaces.TableRow, j: number) => (
          <tr>
            {tableRow.Cells.map((cell: interfaces.TableCell, i: number) => {
              if (
                (block.Table.HasRowHeader && i === 0) ||
                (block.Table.HasColumnHeader && j === 0)
              ) {
                return (
                  <th>
                    {cell.RichTexts.map((richText: interfaces.RichText) => (
                      <RichText richText={richText} />
                    ))}
                  </th>
                );
              }
              return (
                <td>
                  {cell.RichTexts.map((richText: interfaces.RichText) => (
                    <RichText richText={richText} />
                  ))}
                </td>
              );
            })}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  /* Framed table per DESIGN.md recipe: chrome-bordered, rounded, lifted off
     the page. Header cells get the glossy chrome-slab treatment; body cells
     are separated by hairlines with a subtle zebra + hover, so the table
     reads as a piece of lit hardware rather than a bare browser grid. */
  .table {
    margin: 1.1em 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--chrome-border);
    border-radius: var(--radius);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      0 3px 12px rgba(20, 40, 80, 0.12);
  }
  .table table {
    margin: 0;
    min-width: max-content;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .table th,
  .table td {
    padding: 0.5rem 0.9rem;
    white-space: normal;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--chrome-border);
    border-right: 1px solid
      color-mix(in oklab, var(--chrome-border) 55%, transparent);
  }
  .table th:last-child,
  .table td:last-child {
    border-right: none;
  }
  .table tr:last-child th,
  .table tr:last-child td {
    border-bottom: none;
  }
  /* Header cells: glossy chrome slab. */
  .table th {
    font-weight: 700;
    color: var(--fg);
    background: linear-gradient(
      180deg,
      var(--chrome-bright) 0%,
      var(--chrome-mid) 55%,
      var(--chrome-shade) 100%
    );
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      inset 0 -1px 0 var(--chrome-rim-bottom);
  }
  .table td {
    font-weight: normal;
    background: rgba(255, 255, 255, 0.4);
  }
  /* Zebra striping + hover for body rows. */
  .table tbody tr:nth-child(even) td {
    background: rgba(226, 236, 247, 0.35);
  }
  .table tbody tr:hover td {
    background: color-mix(in oklab, var(--aqua-bright) 12%, white);
  }

  @media (prefers-color-scheme: dark) {
    .table {
      box-shadow:
        inset 0 1px 0 var(--chrome-rim),
        0 3px 14px rgba(0, 0, 0, 0.35);
    }
    .table td {
      background: rgba(255, 255, 255, 0.02);
    }
    .table tbody tr:nth-child(even) td {
      background: rgba(255, 255, 255, 0.045);
    }
    .table tbody tr:hover td {
      background: color-mix(in oklab, var(--aqua-mid) 16%, transparent);
    }
  }
</style>
