---
import * as interfaces from '../../lib/interfaces.ts';
import { snakeToKebab } from '../../lib/style-helpers.ts';
import RichText from './RichText.astro';
import NotionBlocks from '../NotionBlocks.astro';
import '../../styles/notion-color.css';

export interface Props {
  block: interfaces.Block;
  headings: interfaces.Block[];
}

const { block, headings } = Astro.props;
---

<blockquote class={snakeToKebab(block.Quote.Color)}>
  {
    block.Quote.RichTexts.map((richText: interfaces.RichText) => (
      <RichText richText={richText} />
    ))
  }
  {
    block.Quote.Children && (
      <NotionBlocks blocks={block.Quote.Children} headings={headings} />
    )
  }
</blockquote>

<style>
  /* Quote keeps its traditional left rule (per DESIGN.md) but the flat gray
     fill is replaced with a glassy aqua-tinted panel + inset top highlight,
     and the rule itself becomes a glossy aqua bar, matching the wet-glass
     sheen used across the chrome components. */
  blockquote {
    position: relative;
    margin: 1.2em 0;
    padding: 0.55rem 1.1rem 0.55rem 1.15rem;
    border: 1px solid var(--chrome-border);
    border-left: none;
    border-radius: 0 var(--radius) var(--radius) 0;
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--aqua-bright) 12%, white) 0%,
      color-mix(in oklab, var(--aqua-bright) 6%, white) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 2px 8px rgba(20, 40, 80, 0.08);
    font-size: 1rem;
    line-height: 1.8;
  }
  /* Glossy aqua left bar (vertical gradient) — the "rule" as a lit metal edge. */
  blockquote::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 4px;
    background: linear-gradient(
      180deg,
      var(--aqua-bright),
      var(--aqua-mid) 55%,
      var(--aqua-shade)
    );
    box-shadow: inset 1px 0 0 rgba(255, 255, 255, 0.45);
  }
  blockquote :global(p:first-child) {
    margin-top: 0;
  }
  blockquote :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (prefers-color-scheme: dark) {
    blockquote {
      background: linear-gradient(
        180deg,
        color-mix(in oklab, var(--aqua-mid) 20%, transparent) 0%,
        color-mix(in oklab, var(--aqua-mid) 8%, transparent) 100%
      );
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 2px 8px rgba(0, 0, 0, 0.32);
    }
  }
</style>
