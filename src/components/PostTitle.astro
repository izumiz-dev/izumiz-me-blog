---
import type { Post, GalleryItem } from '../lib/interfaces.ts';
import { getPostLink } from '../lib/blog-helpers.ts';

export interface Props {
  post: Post | GalleryItem;
  enableLink: boolean;
}

const { post, enableLink = true } = Astro.props;

let title = post.Title;
---

<h2 class="post-title">
  {
    enableLink ? (
      <a href={getPostLink(post.Slug)}>
        {post.Icon && post.Icon.Type === 'emoji' ? (
          <>
            <span>{post.Icon.Emoji}</span>
            {title}
          </>
        ) : post.Icon && post.Icon.Type === 'external' ? (
          <>
            <img src={post.Icon.Url} alt="Post title icon" />
            {title}
          </>
        ) : (
          title
        )}
      </a>
    ) : (
      <>
        {post.Icon && post.Icon.Type === 'emoji' ? (
          <>
            <span>{post.Icon.Emoji}</span>
            {title}
          </>
        ) : post.Icon && post.Icon.Type === 'external' ? (
          <>
            <img src={post.Icon.Url} alt="Post title icon" />
            {title}
          </>
        ) : (
          title
        )}
      </>
    )
  }
</h2>

<style>
  .post-title {
    margin: 0.4rem 0 1.2rem;
    padding: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--fg);
    letter-spacing: 0.01em;
    font-feature-settings: 'palt' 1;
  }
  .post-title a {
    display: inline-block;
    font-size: 1.6rem;
    color: inherit;
  }
  .post-title span,
  .post-title img {
    display: inline-block;
    margin-right: 0.2em;
  }
  .post-title span {
    font-size: 1.2em;
  }
  .post-title img {
    width: 1.3em;
    height: 1.3em;
    vertical-align: sub;
  }
  @media (max-width: 640px) {
    .post-title {
      font-size: 1.65rem;
      line-height: 1.4;
      margin: 0.3rem 0 1rem;
    }
    .post-title a {
      font-size: 1.45rem;
    }
  }
</style>
