---
import type { Post, GalleryItem } from '../lib/interfaces.ts';
import { getPostLink } from '../lib/blog-helpers.ts';

export interface Props {
  post: Post | GalleryItem;
  enableLink: boolean;
  linkHref?: string;
}

const { post, enableLink = true, linkHref, stretched = false } = Astro.props;

const href = linkHref ?? getPostLink(post.Slug);
let title = post.Title;
---

<h2 class="post-title">
  {
    enableLink ? (
      <a href={href} class:list={stretched ? 'stretched-link' : undefined}>
        {post.Icon && post.Icon.Type === 'emoji' ? (
          <>
            <span>{post.Icon.Emoji}</span>
            {title}
          </>
        ) : post.Icon && post.Icon.Type === 'external' ? (
          <>
            <img src={post.Icon.Url} alt="Post title icon" />
            {title}
          </>
        ) : (
          title
        )}
      </a>
    ) : (
      <>
        {post.Icon && post.Icon.Type === 'emoji' ? (
          <>
            <span>{post.Icon.Emoji}</span>
            {title}
          </>
        ) : post.Icon && post.Icon.Type === 'external' ? (
          <>
            <img src={post.Icon.Url} alt="Post title icon" />
            {title}
          </>
        ) : (
          title
        )}
      </>
    )
  }
</h2>

<style>
  .post-title {
    margin: 0.4rem 0 1rem;
    padding: 0;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--fg);
    letter-spacing: -0.01em;
    font-feature-settings: 'palt' 1;
  }
  /* Detail-page title: bigger, groove line underneath */
  .post-title:not(:has(a)) {
    position: relative;
  }
  .post-title:not(:has(a)) {
    font-size: 1.9rem;
    font-weight: 800;
    padding: 0 0 0.8rem 0;
    margin-bottom: 1.4rem;
  }
  .post-title:not(:has(a))::after {
    content: '';
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(180, 200, 240, 0.7) 30%,
      rgba(140, 170, 220, 0.9) 50%,
      rgba(180, 200, 240, 0.7) 70%,
      transparent 100%
    );
  }
  @media (prefers-color-scheme: dark) {
    .post-title:not(:has(a))::after {
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(140, 170, 220, 0.45) 30%,
        rgba(180, 200, 240, 0.6) 50%,
        rgba(140, 170, 220, 0.45) 70%,
        transparent 100%
      );
    }
  }
  .post-title a {
    display: inline-block;
    font-size: inherit;
    color: inherit;
  }
  /* Stretched link: ::after でカード全体を覆い、クリックで遷移させる。
     定位先は祖先のカード枠(.postCard / .timeline-card の position:relative)。 */
  .post-title a.stretched-link::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
  }
  .post-title span,
  .post-title img {
    display: inline-block;
    margin-right: 0.2em;
  }
  .post-title span {
    font-size: 1.2em;
  }
  .post-title img {
    width: 1.3em;
    height: 1.3em;
    vertical-align: sub;
  }
  @media (max-width: 640px) {
    .post-title {
      font-size: 1.15rem;
      line-height: 1.4;
      margin: 0.3rem 0 0.8rem;
    }
    .post-title:not(:has(a)) {
      font-size: 1.5rem;
      padding: 0 0 0.6rem 0;
    }
  }
</style>
