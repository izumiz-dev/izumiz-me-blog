---
import { getPageLink } from '../lib/blog-helpers.ts';

export interface Props {
  currentPage: number;
  numberOfPages: number;
  tag?: string; // tag をオプショナルに変更
  basePath?: string;
}

const {
  currentPage,
  numberOfPages,
  tag,
  basePath = Astro.url.pathname.startsWith('/gallery') ? '/gallery' : '/posts',
} = Astro.props;

const isFirstPage = currentPage === 1;
const isLastPage = currentPage === numberOfPages;
const previousPage = currentPage - 1;
const nextPage = currentPage + 1;

const startPage = currentPage - 2 < 1 ? 1 : currentPage - 2;
const endPage =
  currentPage + 2 > numberOfPages ? numberOfPages : currentPage + 2;

let pages = [];
for (let i = startPage; i <= endPage; i++) {
  pages.push(i);
}
---

<div class="pagination">
  {
    !isFirstPage && (
      <a href={getPageLink(previousPage, tag || '', basePath)}>{'<'}</a>
    )
  }
  {
    pages.map((p: number) => (
      <a
        href={getPageLink(p, tag || '', basePath)}
        class={`${p === currentPage ? 'is-current' : ''} ${p === currentPage && basePath.startsWith('/posts') ? 'active-blog' : ''} ${p === currentPage && basePath.startsWith('/gallery') ? 'active-gallery' : ''}`}
      >
        {p}
      </a>
    ))
  }
  {
    !isLastPage && (
      <a href={getPageLink(nextPage, tag || '', basePath)}>{'>'}</a>
    )
  }
</div>

<style>
  .pagination {
    display: flex;
    width: 100%;
    margin: 0 auto;
    color: var(--fg);
    justify-content: center;
    align-items: center;
  }
  .pagination a {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 3rem;
    height: 3rem;
    margin: 0 0.4rem;
    border-radius: 50%;
    background: var(--chrome-gradient);
    border: 1px solid var(--chrome-border);
    color: var(--my-fg-color);
    font-size: 0.85rem;
    text-align: center;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      inset 0 -1px 0 var(--chrome-rim-bottom),
      0 1px 2px rgba(0, 0, 0, 0.08);
    position: relative;
    overflow: hidden;
  }
  .pagination a::before {
    /* ホバー時のグラデーション用 */
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .pagination a:hover:not(.is-current)::before {
    left: 100%;
  }
  .pagination a:hover:not(.is-current) {
    filter: brightness(1.04);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      inset 0 -1px 0 var(--chrome-rim-bottom),
      0 2px 6px rgba(0, 0, 0, 0.12);
    transform: translateY(-1px);
  }
  .pagination a.is-current {
    background: var(--aqua-gradient);
    color: #fff;
    border-color: var(--aqua-shade);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 -1px 0 rgba(0, 0, 0, 0.2),
      0 1px 2px rgba(0, 0, 0, 0.08);
    cursor: default;
    font-weight: bold;
  }
  .pagination a.is-current:hover {
    transform: none;
    filter: none;
  }
</style>
