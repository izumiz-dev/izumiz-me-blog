---
import type { Post, SelectProperty } from '../lib/interfaces.ts';
import { getTagLink } from '../lib/blog-helpers.ts';
import '../styles/notion-color.css';

export interface Props {
  post: Post;
  enableLink?: boolean;
  basePath?: string;
}

const { post, enableLink, basePath = '/posts' } = Astro.props;
---

<div class="post-tags">
  {
    post.Tags &&
      post.Tags.length > 0 &&
      post.Tags.map((tag: SelectProperty) => {
        if (enableLink) {
          return (
            <a href={getTagLink(tag.name, basePath)} class={`tag ${tag.color}`}>
              {tag.name}
            </a>
          );
        }
        return <span class={`tag ${tag.color}`}>{tag.name}</span>;
      })
  }
</div>

<style>
  .post-tags {
    font-size: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 0.6rem;
  }
  .post-tags a,
  .post-tags span {
    flex-shrink: 1;
    min-width: 0;
    text-decoration: none;
  }
  /* タグリンクは stretched link の ::after より手前に置き、
     カード遷移と独立してタグ絞り込み遷移を動かす */
  .post-tags a {
    position: relative;
    z-index: 2;
  }
</style>
