---
import type { BookReview } from '../lib/interfaces';
import {
  getBookReviewLink,
  renderStars,
  getFeaturedImageUrl,
} from '../lib/blog-helpers';

export interface Props {
  post: BookReview;
}

const { post } = Astro.props;
const stars = renderStars(post.Rating);
const imageUrl = getFeaturedImageUrl(post.FeaturedImage);
---

<div class="book-review-tile">
  <a href={getBookReviewLink(post.Slug)}>
    {
      imageUrl && (
        <div class="book-cover-wrap">
          <img
            class="book-cover"
            src={imageUrl}
            alt={post.Title}
            loading="lazy"
          />
        </div>
      )
    }
    <h2 class="book-title" title={post.Title}>
      {post.Title}
    </h2>
    {post.Author && <p class="book-author">{post.Author}</p>}
    <div class="book-meta">
      {post.Rating > 0 && <span class="book-rating">{stars}</span>}
      {
        post.ReadingStatus && (
          <span class="book-status">{post.ReadingStatus}</span>
        )
      }
    </div>
  </a>
</div>

<style>
  .book-review-tile {
    display: flex;
    flex-direction: column;
  }

  .book-review-tile a {
    color: inherit;
    text-decoration: none;
  }

  .book-cover-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--chrome-border);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      0 3px 12px rgba(20, 40, 80, 0.12);
  }
  @media (prefers-color-scheme: dark) {
    .book-cover-wrap {
      box-shadow:
        inset 0 1px 0 var(--chrome-rim),
        0 3px 14px rgba(0, 0, 0, 0.35);
    }
  }

  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .book-title {
    margin: 0.5rem 0 0;
    font-size: 1rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
  }

  .book-author {
    margin: 0.2rem 0 0;
    font-size: 0.85rem;
    color: var(--fg-subtle);
  }

  .book-meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-top: 0.3rem;
    font-size: 0.8rem;
  }

  .book-rating {
    color: var(--aqua-mid);
    letter-spacing: 0.05em;
  }

  .book-status {
    color: var(--fg-subtle);
  }

  @media (max-width: 640px) {
    .book-title {
      font-size: 0.9rem;
    }
  }
</style>
