---
import { filePath } from '../lib/blog-helpers';

const { post } = Astro.props;

let image = '';
if (post.FeaturedImage && post.FeaturedImage.Url) {
  if (import.meta.env.DEV) {
    image = post.FeaturedImage.Url;
  } else {
    image = filePath(new URL(post.FeaturedImage.Url));
  }
}
---

{
  image && (
    <div class="image-container">
      <a data-fslightbox="gallery" href={image} data-type="image">
        <img src={image} alt="Featured image of the post" loading="lazy" />
      </a>
    </div>
  )
}

<style>
  .image-container {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--chrome-border);
    box-shadow:
      inset 0 1px 0 var(--chrome-rim),
      0 3px 12px rgba(20, 40, 80, 0.12);
  }
  @media (prefers-color-scheme: dark) {
    .image-container {
      box-shadow:
        inset 0 1px 0 var(--chrome-rim),
        0 3px 14px rgba(0, 0, 0, 0.35);
    }
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 640px) {
    .image-container {
      aspect-ratio: 1 / 1; /* モバイルでも正方形にする */
      width: 100%; /* コンテナ自体も幅100%に */
      overflow: hidden; /* はみ出し防止 */
    }
    .image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover; /* 正方形にカットアウト */
      object-position: center;
      display: block; /* 余計なスペースを取り除く */
    }
  }
</style>
