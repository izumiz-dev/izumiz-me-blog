---
import type { SelectProperty, BookReview } from '@lib/interfaces.ts';
import {
  getPostsByTagAndPage,
  getAllTags,
  getNumberOfPagesByTag,
} from '@lib/notion/client.ts';
import Layout from '@layouts/Layout.astro';
import NoContents from '@components/NoContents.astro';
import Pagination from '@components/Pagination.astro';
import BlogTagsLink from '@components/BlogTagsLink.astro';
import BookReviewCard from '@components/BookReviewCard.astro';
import styles from '@styles/blog.module.css';
import '@styles/notion-color.css';

export async function getStaticPaths() {
  const allTags = await getAllTags('bookReview');

  let params = [];

  await Promise.all(
    allTags.map((tag: SelectProperty) => {
      return getNumberOfPagesByTag(tag.name, 'bookReview').then(
        (numberOfPages: number) => {
          for (let i = 2; i <= numberOfPages; i++) {
            params.push({ params: { tag: tag.name, page: i.toString() } });
          }
        }
      );
    })
  );

  return params;
}

const { tag, page } = Astro.params;

const [posts, tags, numberOfPages] = await Promise.all([
  getPostsByTagAndPage(tag, parseInt(page, 10), 'bookReview'),
  getAllTags('bookReview'),
  getNumberOfPagesByTag(tag, 'bookReview'),
]);

const currentTag = posts[0].Tags.find((t) => t.name === tag);
---

<Layout
  title={`Book Reviews in ${tag} ${page}/${numberOfPages}`}
  path={`/book-reviews/tag/${tag}/page/${page}`}
  description={`Filtered book reviews by tag: ${tag}`}
  ogImage=""
  openGraph={{
    basic: {
      title: `Book Reviews in ${tag}`,
      type: 'website',
      image: '',
    },
    image: { alt: `Book Reviews in ${tag}` },
  }}
>
  <div slot="main" class={styles.main}>
    <header>
      <div class="tag-container">
        <span class={`tag ${currentTag.color}`}>{tag}</span>
        {page}/{numberOfPages}
      </div>
    </header>

    {
      posts.length === 0 ? (
        <NoContents contents={posts} />
      ) : (
        (posts as BookReview[]).map((post) => (
          <div class={styles.postCard} key={post.Slug}>
            <BookReviewCard post={post} />
          </div>
        ))
      )
    }

    <footer style={{ maxWidth: '840px' }}>
      <Pagination
        tag={tag}
        currentPage={parseInt(page, 10)}
        numberOfPages={numberOfPages}
        basePath="/book-reviews"
      />
    </footer>
  </div>

  <div slot="aside" class={styles.aside}>
    <BlogTagsLink heading="タグ一覧" tags={tags} basePath="/book-reviews" />
  </div>
</Layout>

<style>
  .tag-container {
    margin: 0;
    line-height: 1.3;
    font-size: 1.2rem;
    font-weight: normal;
  }
  @media (max-width: 640px) {
    .tag-container {
      font-size: 1.15rem;
    }
  }
  .tag-container span.tag {
    border-radius: 12px;
    padding: 3px 9px;
  }
</style>
